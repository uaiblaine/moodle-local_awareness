{{!
    @template local_awareness/editor/manage_shell

    Light-touch wrapper that gives the manage page the same chrome (top bar,
    page heading, brand) as the editor. The actual table is passed in as raw
    HTML via the tablehtml context variable.

    Context variables required:
    * pagetitle (string)
    * subtitle (string)
    * createurl (string)
    * createlabel (string)
    * tablehtml (raw HTML)

    Example context (json):
    {
        "pagetitle": "Manage notices",
        "subtitle": "Create and manage modal notices.",
        "createurl": "/local/awareness/editnotice.php",
        "createlabel": "Create new notice",
        "tablehtml": "<table><tr><td>Example</td></tr></table>"
    }
}}
<div class="local-awareness-editor local-awareness-editor--manage">

    <div class="la-shell la-shell--single">
        <main class="la-shell-main">
            <div class="la-pagehead">
                <div class="la-pagehead-title">
                    <h1>{{pagetitle}}</h1>
                    <p class="la-pagehead-sub">{{subtitle}}</p>
                </div>
                <div class="la-pagehead-meta">
                    <a class="la-btn la-btn--brand" href="{{createurl}}">
                        <i class="fa fa-plus" aria-hidden="true"></i> {{createlabel}}
                    </a>
                </div>
            </div>

            <div class="la-card la-card--plain">
                <div class="la-card-body">
                    {{{tablehtml}}}
                </div>
            </div>
        </main>
    </div>
</div>
