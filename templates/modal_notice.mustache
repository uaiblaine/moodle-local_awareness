{{!
    @template local_awareness/modal_notice

    Template for modal pop up.

    Context variables required for this template:
      * classes
      * uniqid
      * headerclasses
      * header
      * title
      * body
      * footer

    Example context (json):
    {
        "classes": "classes",
        "uniqid": "uniqid",
        "headerclasses": "headerclasses",
        "header": "header",
        "title": "title",
        "body": "body",
        "footer": "footer"
    }
}}

<div class="modal moodle-has-zindex" data-region="modal-container" aria-hidden="true" role="dialog">
    <div class="modal-dialog awareness modal-lg {{$classes}}{{/classes}}" role="document" data-region="modal" aria-labelledby="{{uniqid}}-modal-title" tabindex="0">
        <div class="modal-content shadow-lg border-0 rounded-lg">
            <div class="modal-header bg-light border-bottom-0 {{$headerclasses}}{{headerclasses}}{{/headerclasses}}" data-region="header">
                {{$header}}
                    <h5 id="{{uniqid}}-modal-title" class="modal-title font-weight-bold" data-region="title">{{$title}}{{title}}{{/title}}</h5>
                    <button id="awareness-closebtn" type="button" class="close" data-action="close" aria-label="{{#str}} close, core {{/str}}">
                        <span aria-hidden="true">&times;</span>
                    </button>
                {{/header}}
            </div>
            <div class="modal-body px-4 py-3" data-region="body">
                {{$body}}
                    {{{body}}}
                {{/body}}
            </div>
            <div class="modal-footer bg-white border-top-0 d-flex justify-content-between align-items-center px-4 pb-4" data-region="footer">
                {{$footer}}
                     <div class="form-check d-none" id="awareness-ack-container">
                        <input type="checkbox" class="form-check-input" id="awareness-modal-ackcheckbox">
                        <label class="form-check-label ml-2" for="awareness-modal-ackcheckbox">
                            {{#str}} modal:checkboxtext, local_awareness {{/str}}
                        </label>
                    </div>
                    <div class="ml-auto">
                        <button id="awareness-acceptbtn" type="button" class="btn btn-primary px-4" data-action="accept">
                            {{#str}} button:accept, local_awareness {{/str}}
                        </button>
                    </div>
                {{/footer}}
            </div>
        </div>
    </div>
</div>
